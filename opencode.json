{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "letta": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Letta Memory",
      "options": {
        "baseURL": "http://localhost:8283/v1"
      },
      "models": {
        "agent-a33fc41c-604e-417a-b0ce-a0a8fa5bfd96": {
          "name": "Letta Brain (llama3.2)"
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Local",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:latest": {
          "name": "Gemma 4"
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "timeout": 30000
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "enabled": false
    }
  }
}
